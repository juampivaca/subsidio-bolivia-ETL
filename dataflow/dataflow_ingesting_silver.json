			"scriptLines": [
				"source(output(",
				"          almacen_id as string,",
				"          nombre as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          direccion as string,",
				"          capacidad_m3 as string,",
				"          estado as string,",
				"          {_ingested_at} as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source(output(",
				"          despacho_id as string,",
				"          recepcion_id as string,",
				"          nro_lote as string,",
				"          almacen_id as string,",
				"          transportista_id as string,",
				"          vehiculo_id as string,",
				"          fecha_despacho as string,",
				"          cantidad_despachada as string,",
				"          centro_destino as string,",
				"          estado as string,",
				"          responsable as string,",
				"          nro_guia_despacho as string,",
				"          fecha_llegada as string,",
				"          {_ingested_at} as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source2",
				"source(output(",
				"          recepcion_id as string,",
				"          nro_lote as string,",
				"          almacen_id as string,",
				"          transportista_id as string,",
				"          vehiculo_id as string,",
				"          fecha_recepcion as string,",
				"          cantidad_recibida as string,",
				"          unidad as string,",
				"          condicion as string,",
				"          estado as string,",
				"          responsable as string,",
				"          nro_guia_remision as string,",
				"          temperatura_llegada as string,",
				"          {_ingested_at} as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source3",
				"source(output(",
				"          transportista_id as string,",
				"          razon_social as string,",
				"          nit as string,",
				"          municipio as string,",
				"          contacto as string,",
				"          telefono as string,",
				"          estado as string,",
				"          {_ingested_at} as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source4",
				"source(output(",
				"          vehiculo_id as string,",
				"          transportista_id as string,",
				"          descripcion as string,",
				"          placa as string,",
				"          tipo as string,",
				"          capacidad_kg as string,",
				"          estado as string,",
				"          {_ingested_at} as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source5",
				"source(output(",
				"          ci as string,",
				"          nombres as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          fecha_nacimiento as string,",
				"          genero as string,",
				"          estado_civil as string,",
				"          municipio as string,",
				"          {_ingested_at} as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source6",
				"source(output(",
				"          afiliacion_id as string,",
				"          ci_beneficiaria as string,",
				"          empleador_id as string,",
				"          caja_id as string,",
				"          fecha_afiliacion as string,",
				"          nro_matricula as string,",
				"          tipo_subsidio as string,",
				"          estado as string,",
				"          {_ingested_at} as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source7",
				"source(allowSchemaDrift: true,",
				"     validateSchema: false) ~> source8",
				"source(allowSchemaDrift: true,",
				"     validateSchema: false) ~> source9",
				"source(allowSchemaDrift: true,",
				"     validateSchema: false) ~> source10",
				"source(allowSchemaDrift: true,",
				"     validateSchema: false) ~> source11",
				"source(allowSchemaDrift: true,",
				"     validateSchema: false) ~> source12",
				"source(allowSchemaDrift: true,",
				"     validateSchema: false) ~> source13",
				"source(allowSchemaDrift: true,",
				"     validateSchema: false) ~> source14",
				"source2 cast(output(",
				"          despacho_id as integer,",
				"          recepcion_id as integer,",
				"          nro_lote as string,",
				"          almacen_id as integer,",
				"          transportista_id as integer,",
				"          vehiculo_id as integer,",
				"          fecha_despacho as string,",
				"          centro_destino as string,",
				"          estado as string,",
				"          responsable as string,",
				"          nro_guia_despacho as string,",
				"          {_ingested_at} as timestamp",
				"     ),",
				"     errors: true) ~> cast1",
				"source1 cast(output(",
				"          almacen_id as integer,",
				"          nombre as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          direccion as string,",
				"          capacidad_m3 as integer,",
				"          estado as string,",
				"          {_ingested_at} as timestamp",
				"     ),",
				"     errors: true) ~> cast2",
				"cast2 derive(abreviacion_departamento = case(\r",
				"    departamento == 'La Paz',      'LP',\r",
				"    departamento == 'Cochabamba',  'CB',\r",
				"    departamento == 'Santa Cruz',  'SC',\r",
				"    departamento == 'Oruro',       'OR',\r",
				"    departamento == 'Potosí',      'PT',\r",
				"    departamento == 'Tarija',      'TJ',\r",
				"    departamento == 'Chuquisaca',  'CH',\r",
				"    departamento == 'Beni',        'BE',\r",
				"    departamento == 'Pando',       'PD',\r",
				"    departamento\r",
				")) ~> derivedColumn1",
				"cast1 derive(nro_lote = upper(trim(nro_lote)),",
				"          fecha_despacho = coalesce(\r",
				"    toDate(fecha_despacho, 'yyyy-MM-dd'),\r",
				"    toDate(fecha_despacho, 'dd/MM/yyyy'),\r",
				"    toDate(fecha_despacho, 'MM/dd/yyyy'),\r",
				"    toDate(fecha_despacho, 'dd-MM-yyyy'),\r",
				"    toDate(fecha_despacho, 'MM-dd-yyyy')\r",
				"),",
				"          fecha_llegada = coalesce(\r",
				"    toDate(fecha_llegada, 'yyyy-MM-dd'),\r",
				"    toDate(fecha_llegada, 'dd/MM/yyyy'),\r",
				"    toDate(fecha_llegada, 'MM/dd/yyyy'),\r",
				"    toDate(fecha_llegada, 'dd-MM-yyyy'),\r",
				"    toDate(fecha_llegada, 'MM-dd-yyyy')\r",
				"),",
				"          cantidad_despachada = toDecimal(regexReplace(toString(cantidad_despachada), '[^0-9.]', '')),",
				"          centro_destino = initCap(regexReplace(trim(toString(centro_destino)), '\\\\s+', ' ')),",
				"          estado = case(\r",
				"    regexMatch(lower(trim(toString(estado))), 'dep|des|dsp|pac|spa'), 'Despachado',\r",
				"    regexMatch(lower(trim(toString(estado))), 'dev'),                  'Devuelto',\r",
				"    regexMatch(lower(trim(toString(estado))), '[aá]ns'),               'En Tránsito',\r",
				"    regexMatch(lower(trim(toString(estado))), 'entr|ntreg|nteg|nter'), 'Entregado',\r",
				"    iifNull(trim(toString(estado)), 'Sin Estado')\r",
				"),",
				"          responsable = initCap(regexReplace(trim(toString(responsable)), '\\\\s+', ' ')),",
				"          nro_guia_despacho = upper(trim(toString(nro_guia_despacho)))) ~> derivedColumn2",
				"derivedColumn2 filter(!isNull(fecha_despacho) && trim(toString(fecha_despacho)) != '') ~> filter1",
				"filter1 derive(centro_destino = iifNull(initCap(regexReplace(trim(toString(centro_destino)), '\\\\s+', ' ')), 'Sin Destino'),",
				"          dias_en_transito = iif(\r",
				"    !isNull(fecha_llegada) && !isNull(fecha_despacho),\r",
				"    toInteger(toLong(fecha_llegada) - toLong(fecha_despacho)),\r",
				"    toInteger(null())\r",
				"),",
				"          despacho_cumplido = iif(in(['Despachado', 'Entregado'], estado), true(), false()),",
				"          anio_despacho = year(fecha_despacho),",
				"          mes_despacho = month(fecha_despacho)) ~> derivedColumn3",
				"source3 cast(output(",
				"          recepcion_id as integer,",
				"          nro_lote as string,",
				"          almacen_id as integer,",
				"          transportista_id as integer,",
				"          vehiculo_id as integer,",
				"          fecha_recepcion as string,",
				"          cantidad_recibida as double,",
				"          unidad as string,",
				"          condicion as string,",
				"          estado as string,",
				"          responsable as string,",
				"          nro_guia_remision as string,",
				"          temperatura_llegada as double,",
				"          {_ingested_at} as timestamp",
				"     ),",
				"     errors: true) ~> cast3",
				"cast3 derive(nro_lote = upper(trim(toString(nro_lote))),",
				"          fecha_recepcion = coalesce(\r",
				"    toDate(fecha_recepcion, 'yyyy-MM-dd'),\r",
				"    toDate(fecha_recepcion, 'dd/MM/yyyy'),\r",
				"    toDate(fecha_recepcion, 'MM/dd/yyyy'),\r",
				"    toDate(fecha_recepcion, 'dd-MM-yyyy')\r",
				"),",
				"          unidad = lower(trim(toString(unidad))),",
				"          condicion = case(\r",
				"    regexMatch(lower(trim(toString(condicion))), 'da[nñ]|da[oó]'), 'Dañado',\r",
				"    regexMatch(lower(trim(toString(condicion))), 'regul|rgula'),   'Regular',\r",
				"    regexMatch(lower(trim(toString(condicion))), 'bue|ben|bueo'),  'Bueno',\r",
				"    trim(toString(condicion))\r",
				"),",
				"          estado = case(\r",
				"    regexMatch(lower(trim(toString(estado))), 'observ'),           'Recibido con Observación',\r",
				"    regexMatch(lower(trim(toString(estado))), 'verif'),            'En Verificación',\r",
				"    regexMatch(lower(trim(toString(estado))), 'rechaz|rechz'),     'Rechazado',\r",
				"    regexMatch(lower(trim(toString(estado))), 'rec|rcib|reib'),    'Recibido',\r",
				"    trim(toString(estado))\r",
				"),",
				"          responsable = initCap(regexReplace(trim(toString(responsable)), '\\\\s+', ' ')),",
				"          nro_guia_remision = upper(trim(toString(nro_guia_remision))),",
				"          temperatura_anomala = iif(\r",
				"    !isNull(temperatura_llegada) && temperatura_llegada > 40,\r",
				"    true(),\r",
				"    false()\r",
				")) ~> derivedColumn4",
				"derivedColumn4 filter(!isNull(recepcion_id) && trim(toString(fecha_recepcion)) != '') ~> filter2",
				"filter2 derive(anio_recepcion = year(fecha_recepcion),",
				"          mes_recepcion = month(fecha_recepcion)) ~> derivedColumn5",
				"source4 cast(output(",
				"          transportista_id as integer",
				"     ),",
				"     errors: true) ~> cast4",
				"cast4 derive(abreviacion_municipio = case(\r",
				"    municipio== 'La Paz',      'LP',\r",
				"    municipio== 'Cochabamba',  'CB',\r",
				"    municipio== 'Santa Cruz de la Sierra',  'SC',\r",
				"    municipio== 'Oruro',       'OR',\r",
				"    municipio== 'Potosí',      'PT',\r",
				"    municipio== 'Tarija',      'TJ',\r",
				"    municipio== 'Chuquisaca',  'CH',\r",
				"    municipio== 'Beni',        'BE',\r",
				"    municipio== 'Trinidad',        'BE',\r",
				"    municipio== 'Pando',       'PD',\r",
				"    municipio\r",
				")) ~> derivedColumn6",
				"source5 cast(output(",
				"          vehiculo_id as integer,",
				"          transportista_id as integer,",
				"          descripcion as string,",
				"          placa as string,",
				"          tipo as string,",
				"          capacidad_kg as integer,",
				"          estado as string,",
				"          {_ingested_at} as timestamp",
				"     ),",
				"     errors: true) ~> cast5",
				"source6 derive(abreviacion_departamento = right(trim(toString(ci)), 2),",
				"          fecha_nacimiento = coalesce(\r",
				"    toDate(fecha_nacimiento, 'yyyy-MM-dd'),\r",
				"    toDate(fecha_nacimiento, 'dd/MM/yyyy'),\r",
				"    toDate(fecha_nacimiento, 'MM/dd/yyyy'),\r",
				"    toDate(fecha_nacimiento, 'dd-MM-yyyy')\r",
				")) ~> derivedColumn7",
				"derivedColumn7 derive(departamento_ci = case(     right(trim(toString(ci)), 2) == 'LP', 'La Paz',     right(trim(toString(ci)), 2) == 'CB', 'Cochabamba',     right(trim(toString(ci)), 2) == 'SC', 'Santa Cruz',     right(trim(toString(ci)), 2) == 'OR', 'Oruro',     right(trim(toString(ci)), 2) == 'PT', 'Potosí',     right(trim(toString(ci)), 2) == 'TJ', 'Tarija',     right(trim(toString(ci)), 2) == 'CH', 'Chuquisaca',     right(trim(toString(ci)), 2) == 'BE', 'Beni',     right(trim(toString(ci)), 2) == 'PD', 'Pando' )) ~> derivedColumn8",
				"source7 cast(output(",
				"          afiliacion_id as integer,",
				"          ci_beneficiaria as string,",
				"          empleador_id as integer,",
				"          caja_id as integer,",
				"          fecha_afiliacion as string,",
				"          nro_matricula as string,",
				"          tipo_subsidio as string,",
				"          estado as string,",
				"          {_ingested_at} as timestamp",
				"     ),",
				"     errors: true) ~> cast6",
				"cast6 derive(abreviacion_departamento_ci = right(trim(toString(ci_beneficiaria)), 2),",
				"          fecha_afiliacion = coalesce(\r",
				"    toDate(fecha_afiliacion, 'yyyy-MM-dd'),\r",
				"    toDate(fecha_afiliacion, 'dd/MM/yyyy'),\r",
				"    toDate(fecha_afiliacion, 'MM/dd/yyyy'),\r",
				"    toDate(fecha_afiliacion, 'dd-MM-yyyy')\r",
				")) ~> derivedColumn9",
				"derivedColumn9 derive(departamento_ci = case(     \r",
				"    right(trim(toString(ci_beneficiaria)), 2) == 'LP', 'La Paz',     \r",
				"    right(trim(toString(ci_beneficiaria)), 2) == 'CB', 'Cochabamba',     \r",
				"    right(trim(toString(ci_beneficiaria)), 2) == 'SC', 'Santa Cruz',     \r",
				"    right(trim(toString(ci_beneficiaria)), 2) == 'OR', 'Oruro',     \r",
				"    right(trim(toString(ci_beneficiaria)), 2) == 'PT', 'Potosí',     \r",
				"    right(trim(toString(ci_beneficiaria)), 2) == 'TJ', 'Tarija',     \r",
				"    right(trim(toString(ci_beneficiaria)), 2) == 'CH', 'Chuquisaca',     \r",
				"    right(trim(toString(ci_beneficiaria)), 2) == 'BE', 'Beni',     \r",
				"    right(trim(toString(ci_beneficiaria)), 2) == 'PD', 'Pando' )) ~> derivedColumn10",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          almacen_id,",
				"          nombre,",
				"          municipio,",
				"          departamento,",
				"          direccion,",
				"          capacidad_m3,",
				"          estado,",
				"          {_ingested_at},",
				"          abreviacion_departamento",
				"     )) ~> sink1",
				"derivedColumn3 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          despacho_id as integer,",
				"          recepcion_id as integer,",
				"          nro_lote as string,",
				"          almacen_id as integer,",
				"          transportista_id as integer,",
				"          vehiculo_id as integer,",
				"          fecha_despacho as date,",
				"          cantidad_despachada as decimal(10,2),",
				"          centro_destino as string,",
				"          estado as string,",
				"          responsable as string,",
				"          nro_guia_despacho as string,",
				"          fecha_llegada as date,",
				"          {_loaded_at} as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          despacho_id,",
				"          recepcion_id,",
				"          nro_lote,",
				"          almacen_id,",
				"          transportista_id,",
				"          vehiculo_id,",
				"          fecha_despacho,",
				"          cantidad_despachada,",
				"          centro_destino,",
				"          estado,",
				"          responsable,",
				"          nro_guia_despacho,",
				"          fecha_llegada",
