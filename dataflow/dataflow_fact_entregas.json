{
	"name": "dataflow_fact_entregas",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_silver_spl_entregas_agencia",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "dim_beneficiaria",
						"type": "DatasetReference"
					},
					"name": "source2"
				},
				{
					"dataset": {
						"referenceName": "dim_canal_entrega",
						"type": "DatasetReference"
					},
					"name": "source3"
				},
				{
					"dataset": {
						"referenceName": "dataset_bronze_spl_entregas_supermercado",
						"type": "DatasetReference"
					},
					"name": "source4"
				},
				{
					"dataset": {
						"referenceName": "dim_canal_entrega",
						"type": "DatasetReference"
					},
					"name": "source5"
				},
				{
					"dataset": {
						"referenceName": "dim_tipo_carne",
						"type": "DatasetReference"
					},
					"name": "source6"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "fact_entregas",
						"type": "DatasetReference"
					},
					"name": "sink1"
				},
				{
					"dataset": {
						"referenceName": "fact_entregas",
						"type": "DatasetReference"
					},
					"name": "sink2"
				}
			],
			"transformations": [
				{
					"name": "lookup1"
				},
				{
					"name": "lookup2"
				},
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "lookup3"
				},
				{
					"name": "lookup4"
				},
				{
					"name": "lookup5"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "select2"
				},
				{
					"name": "filter1"
				},
				{
					"name": "filter2"
				},
				{
					"name": "filter4"
				}
			],
			"scriptLines": [
				"source(output(",
				"          entrega_ag_id as integer,",
				"          asignacion_id as integer,",
				"          ci_beneficiaria as string,",
				"          fecha_entrega as date,",
				"          punto_entrega as string,",
				"          ciudad_entrega as string,",
				"          departamento_entrega as string,",
				"          abrev_depto_entrega as string,",
				"          nro_lote as string,",
				"          cantidad_kg as decimal(6,2),",
				"          sin_detalle_productos as boolean,",
				"          peso_anomalo as boolean,",
				"          anio_entrega as short,",
				"          mes_entrega as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\r\\n    entrega_ag_id,\\r\\n    asignacion_id,\\r\\n    ci_beneficiaria,\\r\\n    fecha_entrega,\\r\\n    punto_entrega,\\r\\n    ciudad_entrega,\\r\\n    departamento_entrega,\\r\\n    abreviacion_departamento    AS abrev_depto_entrega,\\r\\n    lote                        AS nro_lote,\\r\\n    peso_kg                     AS cantidad_kg,\\r\\n    sin_detalle_productos,\\r\\n    peso_anomalo,\\r\\n    anio_entrega,\\r\\n    mes_entrega\\r\\nFROM silver.spl_entregas_agencia',",
				"     format: 'query') ~> source1",
				"source(output(",
				"          beneficiaria_sk as integer,",
				"          ci_beneficiaria as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT beneficiaria_sk, ci_beneficiaria FROM gold.dim_beneficiaria',",
				"     format: 'query') ~> source2",
				"source(output(",
				"          canal_sk as integer,",
				"          nombre_punto as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT canal_sk, nombre_punto FROM gold.dim_canal_entrega',",
				"     format: 'query') ~> source3",
				"source(output(",
				"          entrega_super_id as integer,",
				"          asignacion_id as integer,",
				"          ci_beneficiaria as string,",
				"          supermercado_id as integer,",
				"          tipo_carne as string,",
				"          cantidad_kg as decimal(6,2),",
				"          monto_bs as decimal(10,2),",
				"          ci_sin_departamento as boolean,",
				"          sin_tipo_carne as boolean,",
				"          cantidad_anomala as boolean,",
				"          monto_anomalo as boolean,",
				"          anio_retiro as short,",
				"          mes_retiro as integer,",
				"          fecha_retiro as date",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\n    entrega_super_id,\\n    asignacion_id,\\n    ci_beneficiaria,\\n    supermercado_id,\\n    tipo_carne,\\n    cantidad_kg,\\n    monto_bs,\\n    ci_sin_departamento,\\n    sin_tipo_carne,\\n    cantidad_anomala,\\n    monto_anomalo,\\n    anio_retiro,\\n    mes_retiro,\\n    fecha_retiro\\nFROM silver.spl_entregas_supermercado',",
				"     format: 'query') ~> source4",
				"source(output(",
				"          canal_sk as integer,",
				"          canal_id_nk as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT canal_sk, canal_id_nk FROM gold.dim_canal_entrega\\nWHERE tipo_canal = \\'Supermercado\\'',",
				"     format: 'query') ~> source5",
				"source(output(",
				"          tipo_carne_sk as integer,",
				"          tipo_carne_nk as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT tipo_carne_sk, tipo_carne_nk FROM gold.dim_tipo_carne',",
				"     format: 'query') ~> source6",
				"source1, source2 lookup(source1@ci_beneficiaria == source2@ci_beneficiaria,",
				"     multiple: false,",
				"     pickup: 'first',",
				"     asc(beneficiaria_sk, true),",
				"     broadcast: 'auto')~> lookup1",
				"filter1, source3 lookup(punto_entrega == nombre_punto,",
				"     multiple: false,",
				"     pickup: 'first',",
				"     asc(canal_sk, true),",
				"     broadcast: 'auto')~> lookup2",
				"derivedColumn1 select(mapColumn(",
				"          fecha_entrega,",
				"          ciudad_entrega,",
				"          departamento_entrega,",
				"          abrev_depto_entrega,",
				"          nro_lote,",
				"          cantidad_kg,",
				"          flag_sin_detalle_prods = sin_detalle_productos,",
				"          flag_peso_anomalo = peso_anomalo,",
				"          gestion = anio_entrega,",
				"          mes = mes_entrega,",
				"          beneficiaria_sk,",
				"          canal_sk,",
				"          tipo_canal",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"lookup2 derive(tipo_canal = 'Agencia') ~> derivedColumn1",
				"source4, source2 lookup(source4@ci_beneficiaria == source2@ci_beneficiaria,",
				"     multiple: false,",
				"     pickup: 'first',",
				"     asc(beneficiaria_sk, true),",
				"     broadcast: 'auto')~> lookup3",
				"filter2, source5 lookup(supermercado_id == canal_id_nk,",
				"     multiple: false,",
				"     pickup: 'first',",
				"     asc(canal_id_nk, true),",
				"     broadcast: 'auto')~> lookup4",
				"filter4, source6 lookup(tipo_carne == tipo_carne_nk,",
				"     multiple: false,",
				"     pickup: 'first',",
				"     asc(tipo_carne_sk, true),",
				"     broadcast: 'auto')~> lookup5",
				"lookup5 derive(tipo_canal = 'Supermercado') ~> derivedColumn2",
				"derivedColumn2 select(mapColumn(",
				"          cantidad_kg,",
				"          monto_bs,",
				"          flag_ci_sin_departamento = ci_sin_departamento,",
				"          flag_sin_tipo_carne = sin_tipo_carne,",
				"          flag_cantidad_anomala = cantidad_anomala,",
				"          flag_monto_anomalo = monto_anomalo,",
				"          gestion = anio_retiro,",
				"          mes = mes_retiro,",
				"          beneficiaria_sk,",
				"          canal_sk,",
				"          tipo_carne_sk,",
				"          fecha_entrega = fecha_retiro,",
				"          tipo_canal",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"lookup1 filter(!isNull(beneficiaria_sk)) ~> filter1",
				"lookup3 filter(!isNull(beneficiaria_sk)) ~> filter2",
				"lookup4 filter(!isNull(canal_sk)) ~> filter4",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          entrega_sk as integer,",
				"          beneficiaria_sk as integer,",
				"          canal_sk as integer,",
				"          almacen_sk as integer,",
				"          tipo_carne_sk as integer,",
				"          tipo_canal as string,",
				"          monto_bs as decimal(10,2),",
				"          cantidad_kg as decimal(8,2),",
				"          nro_lote as string,",
				"          ciudad_entrega as string,",
				"          departamento_entrega as string,",
				"          abrev_depto_entrega as string,",
				"          flag_peso_anomalo as boolean,",
				"          flag_cantidad_anomala as boolean,",
				"          flag_monto_anomalo as boolean,",
				"          flag_ci_sin_depto as boolean,",
				"          flag_sin_tipo_carne as boolean,",
				"          flag_sin_detalle_prods as boolean,",
				"          fecha_entrega as date,",
				"          gestion as integer,",
				"          mes as integer",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1",
				"select2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          entrega_sk as integer,",
				"          beneficiaria_sk as integer,",
				"          canal_sk as integer,",
				"          almacen_sk as integer,",
				"          tipo_carne_sk as integer,",
				"          tipo_canal as string,",
				"          monto_bs as decimal(10,2),",
				"          cantidad_kg as decimal(8,2),",
				"          nro_lote as string,",
				"          ciudad_entrega as string,",
				"          departamento_entrega as string,",
				"          abrev_depto_entrega as string,",
				"          flag_peso_anomalo as boolean,",
				"          flag_cantidad_anomala as boolean,",
				"          flag_monto_anomalo as boolean,",
				"          flag_ci_sin_depto as boolean,",
				"          flag_sin_tipo_carne as boolean,",
				"          flag_sin_detalle_prods as boolean,",
				"          fecha_entrega as date,",
				"          gestion as integer,",
				"          mes as integer",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          beneficiaria_sk,",
				"          canal_sk,",
				"          tipo_carne_sk,",
				"          monto_bs,",
				"          cantidad_kg,",
				"          flag_cantidad_anomala,",
				"          flag_monto_anomalo,",
				"          flag_ci_sin_depto = flag_ci_sin_departamento,",
				"          flag_sin_tipo_carne,",
				"          fecha_entrega,",
				"          gestion,",
				"          mes,",
				"          tipo_canal",
				"     )) ~> sink2"
			]
		}
	}
}