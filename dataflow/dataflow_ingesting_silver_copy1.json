{
	"name": "dataflow_ingesting_silver_copy1",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "dataset_bronze_spl_entregas_agencia",
						"type": "DatasetReference"
					},
					"name": "source12"
				},
				{
					"dataset": {
						"referenceName": "dataset_bronze_spl_entregas_supermercado",
						"type": "DatasetReference"
					},
					"name": "source13"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_silver_spl_entregas_agencia",
						"type": "DatasetReference"
					},
					"name": "sink12"
				},
				{
					"dataset": {
						"referenceName": "ds_silver_spl_entregas_supermercado",
						"type": "DatasetReference"
					},
					"name": "sink13"
				}
			],
			"transformations": [
				{
					"name": "cast11"
				},
				{
					"name": "derivedColumn14"
				},
				{
					"name": "derivedColumn15"
				},
				{
					"name": "filter4"
				},
				{
					"name": "cast12"
				},
				{
					"name": "derivedColumn16"
				},
				{
					"name": "filter5"
				}
			],
			"scriptLines": [
				"source(output(",
				"          entrega_ag_id as string,",
				"          asignacion_id as string,",
				"          ci_beneficiaria as string,",
				"          fecha_entrega as string,",
				"          productos as string,",
				"          lote as string,",
				"          peso_kg as string,",
				"          punto_entrega as string,",
				"          {_ingested_at} as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source12",
				"source(output(",
				"          entrega_super_id as string,",
				"          asignacion_id as string,",
				"          ci_beneficiaria as string,",
				"          supermercado_id as string,",
				"          fecha_retiro as string,",
				"          tipo_carne as string,",
				"          cantidad_kg as string,",
				"          monto_bs as string,",
				"          {_ingested_at} as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source13",
				"source12 cast(output(",
				"          entrega_ag_id as integer,",
				"          asignacion_id as integer,",
				"          ci_beneficiaria as string,",
				"          fecha_entrega as string,",
				"          productos as string,",
				"          lote as string,",
				"          peso_kg as double,",
				"          punto_entrega as string,",
				"          {_ingested_at} as timestamp",
				"     ),",
				"     errors: true) ~> cast11",
				"cast11 derive(ci_beneficiaria = upper(regexReplace(regexReplace(trim(toString(ci_beneficiaria)), ' ', ''), '-', '')),",
				"          fecha_entrega = coalesce(\r",
				"    toDate(trim(toString(fecha_entrega)), 'yyyy-MM-dd'),\r",
				"    toDate(trim(toString(fecha_entrega)), 'dd/MM/yyyy'),\r",
				"    toDate(trim(toString(fecha_entrega)), 'MM/dd/yyyy'),\r",
				"    toDate(trim(toString(fecha_entrega)), 'dd-MM-yyyy')\r",
				"),",
				"          lote = upper(trim(toString(lote))),",
				"          punto_entrega = case(\r",
				"    regexMatch(lower(toString(punto_entrega)), '.*el.{0,3}alto.*|.*elalto.*|.*e.{0,2}lalto.*|.*l.{0,2}alto.*'), \r",
				"        'Centro Distribución El Alto',\r",
				"    regexMatch(lower(toString(punto_entrega)), '.*la.{0,3}paz.*|.*lap.{0,2}az.*|.*la.{0,3}az.*'), \r",
				"        'Centro Distribución La Paz',\r",
				"    regexMatch(lower(toString(punto_entrega)), '.*quill.*'), \r",
				"        'Centro Distribución Quillacollo',\r",
				"    regexMatch(lower(toString(punto_entrega)), '.*c[o]{1,2}ch.*|.*chab.*|.*cahb.*|.*cochb.*|.*cchabamba.*|.*cochabamb.*'), \r",
				"        'Centro Distribución Cochabamba',\r",
				"    regexMatch(lower(toString(punto_entrega)), '.*mont.*|.*moter.*|.*mnotero.*'), \r",
				"        'Centro Distribución Montero',\r",
				"    regexMatch(lower(toString(punto_entrega)), '.*(sant|snat|sata).{0,5}(cruz|crz|rcuz|acruz).*'), \r",
				"        'Centro Distribución Santa Cruz',\r",
				"    regexMatch(lower(toString(punto_entrega)), '.*su{1,2}c{1,2}re.*|.*ucre.*'), \r",
				"        'Centro Distribución Sucre',\r",
				"    regexMatch(lower(toString(punto_entrega)), '.*or{1,2}ur.*|.*orro.*|.*oruo.*'), \r",
				"        'Centro Distribución Oruro',\r",
				"    regexMatch(lower(toString(punto_entrega)), '.*p[o]{0,2}to{0,2}s[íi].*|.*ptoosí.*'), \r",
				"        'Centro Distribución Potosí',\r",
				"    regexMatch(lower(toString(punto_entrega)), '.*t.{0,3}arija.*'), \r",
				"        'Centro Distribución Tarija',\r",
				"    regexMatch(lower(toString(punto_entrega)), '.*cob[ia].*'), \r",
				"        'Centro Distribución Cobija'\r",
				"),",
				"          peso_anomalo = case(peso_kg > 20, true(), false())) ~> derivedColumn14",
				"derivedColumn14 derive(anio_entrega = year(fecha_entrega),",
				"          mes_entrega = month(fecha_entrega),",
				"          ciudad_entrega = case(     regexMatch(lower(trim(toString(punto_entrega))), 'el alto'),     'El Alto',     regexMatch(lower(trim(toString(punto_entrega))), 'la paz'),      'La Paz',     regexMatch(lower(trim(toString(punto_entrega))), 'quillacollo'), 'Quillacollo',     regexMatch(lower(trim(toString(punto_entrega))), 'cochabamba'),  'Cochabamba',     regexMatch(lower(trim(toString(punto_entrega))), 'montero'),     'Montero',     regexMatch(lower(trim(toString(punto_entrega))), 'santa cruz'),  'Santa Cruz',     regexMatch(lower(trim(toString(punto_entrega))), 'sucre'),       'Sucre',     regexMatch(lower(trim(toString(punto_entrega))), 'oruro'),       'Oruro',     regexMatch(lower(trim(toString(punto_entrega))), 'potosi|potosí'),'Potosí',     regexMatch(lower(trim(toString(punto_entrega))), 'yacuiba'),     'Yacuiba',     regexMatch(lower(trim(toString(punto_entrega))), 'tarija'),      'Tarija',     regexMatch(lower(trim(toString(punto_entrega))), 'trinidad'),    'Trinidad',     regexMatch(lower(trim(toString(punto_entrega))), 'cobija'),      'Cobija' ),",
				"          departamento_entrega = case(\r",
				"    regexMatch(lower(trim(toString(punto_entrega))), 'el alto|la paz'),      'La Paz',\r",
				"    regexMatch(lower(trim(toString(punto_entrega))), 'quillacollo|cochabamba'), 'Cochabamba',\r",
				"    regexMatch(lower(trim(toString(punto_entrega))), 'montero|santa cruz'),  'Santa Cruz',\r",
				"    regexMatch(lower(trim(toString(punto_entrega))), 'sucre'),               'Chuquisaca',\r",
				"    regexMatch(lower(trim(toString(punto_entrega))), 'oruro'),               'Oruro',\r",
				"    regexMatch(lower(trim(toString(punto_entrega))), 'potosi|potosí'),       'Potosí',\r",
				"    regexMatch(lower(trim(toString(punto_entrega))), 'yacuiba|tarija'),      'Tarija',\r",
				"    regexMatch(lower(trim(toString(punto_entrega))), 'trinidad'),            'Beni',\r",
				"    regexMatch(lower(trim(toString(punto_entrega))), 'cobija'),              'Pando'\r",
				"),",
				"          sin_detalle_productos = iif(isNull(toString(productos)) || trim(toString(productos)) == '', true(), false()),",
				"          abreviacion_departamento = case(\r",
				"    regexMatch(lower(trim(toString(punto_entrega))), 'el alto|la paz'),        'LP',\r",
				"    regexMatch(lower(trim(toString(punto_entrega))), 'quillacollo|cochabamba'),'CB',\r",
				"    regexMatch(lower(trim(toString(punto_entrega))), 'montero|santa cruz'),    'SC',\r",
				"    regexMatch(lower(trim(toString(punto_entrega))), 'sucre'),                 'CH',\r",
				"    regexMatch(lower(trim(toString(punto_entrega))), 'oruro'),                 'OR',\r",
				"    regexMatch(lower(trim(toString(punto_entrega))), 'potosi|potosí'),         'PT',\r",
				"    regexMatch(lower(trim(toString(punto_entrega))), 'yacuiba|tarija'),        'TJ',\r",
				"    regexMatch(lower(trim(toString(punto_entrega))), 'trinidad'),              'BE',\r",
				"    regexMatch(lower(trim(toString(punto_entrega))), 'cobija'),                'PD'\r",
				")) ~> derivedColumn15",
				"derivedColumn15 filter(!isNull(entrega_ag_id) && !isNull(asignacion_id)) ~> filter4",
				"source13 cast(output(",
				"          entrega_super_id as integer,",
				"          asignacion_id as integer,",
				"          ci_beneficiaria as string,",
				"          supermercado_id as integer,",
				"          fecha_retiro as string,",
				"          tipo_carne as string,",
				"          cantidad_kg as decimal(10,0),",
				"          monto_bs as decimal(10,0),",
				"          {_ingested_at} as timestamp",
				"     ),",
				"     errors: true) ~> cast12",
				"cast12 derive(ci_sin_departamento = iif(regexMatch(\r",
				"    upper(regexReplace(regexReplace(trim(toString(ci_beneficiaria)), ' ', ''), '-', '')),\r",
				"    '^\\\\d+$'\r",
				"), true(), false()),",
				"          fecha_retiro = coalesce(\r",
				"    toDate(trim(toString(fecha_retiro)), 'yyyy-MM-dd'),\r",
				"    toDate(trim(toString(fecha_retiro)), 'dd/MM/yyyy'),\r",
				"    toDate(trim(toString(fecha_retiro)), 'MM/dd/yyyy'),\r",
				"    toDate(trim(toString(fecha_retiro)), 'dd-MM-yyyy')\r",
				"),",
				"          tipo_carne = case(     regexMatch(lower(trim(toString(tipo_carne))), '^va|^vca'),  'Vaca',     regexMatch(lower(trim(toString(tipo_carne))), '^po|^pl'),   'Pollo',     regexMatch(lower(trim(toString(tipo_carne))), '^ce|^cr'),   'Cerdo',     regexMatch(lower(trim(toString(tipo_carne))), '^pe|^ps'),   'Pescado' ),",
				"          sin_tipo_carne = iif(isNull(toString(tipo_carne)) || trim(toString(tipo_carne)) == '', true(), false()),",
				"          cantidad_anomala = iif(!isNull(cantidad_kg) && cantidad_kg > 10, true(), false()),",
				"          anio_retiro = year(coalesce(     toDate(trim(toString(fecha_retiro)), 'yyyy-MM-dd'),     toDate(trim(toString(fecha_retiro)), 'dd/MM/yyyy'),     toDate(trim(toString(fecha_retiro)), 'MM/dd/yyyy'),     toDate(trim(toString(fecha_retiro)), 'dd-MM-yyyy') )),",
				"          mes_retiro = month(coalesce(\r",
				"    toDate(trim(toString(fecha_retiro)), 'yyyy-MM-dd'),\r",
				"    toDate(trim(toString(fecha_retiro)), 'dd/MM/yyyy'),\r",
				"    toDate(trim(toString(fecha_retiro)), 'MM/dd/yyyy'),\r",
				"    toDate(trim(toString(fecha_retiro)), 'dd-MM-yyyy')\r",
				")),",
				"          ci_beneficiaria = iif(\r",
				"    regexMatch(\r",
				"        upper(regexReplace(regexReplace(trim(toString(ci_beneficiaria)), ' ', ''), '-', '')),\r",
				"        '^[A-Z]{2}\\\\d+$'\r",
				"    ),\r",
				"    regexReplace(\r",
				"        upper(regexReplace(regexReplace(trim(toString(ci_beneficiaria)), ' ', ''), '-', '')),\r",
				"        '^([A-Z]{2})(\\\\d+)$',\r",
				"        '$2$1'\r",
				"    ),\r",
				"    upper(regexReplace(regexReplace(trim(toString(ci_beneficiaria)), ' ', ''), '-', ''))\r",
				")) ~> derivedColumn16",
				"derivedColumn16 filter(!isNull(entrega_super_id) && !isNull(asignacion_id)) ~> filter5",
				"filter4 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          entrega_ag_id as integer,",
				"          asignacion_id as integer,",
				"          ci_beneficiaria as string,",
				"          fecha_entrega as date,",
				"          productos as string,",
				"          lote as string,",
				"          peso_kg as decimal(6,2),",
				"          punto_entrega as string,",
				"          {_loaded_at} as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink12",
				"filter5 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          entrega_super_id as integer,",
				"          asignacion_id as integer,",
				"          ci_beneficiaria as string,",
				"          supermercado_id as integer,",
				"          fecha_retiro as date,",
				"          tipo_carne as string,",
				"          cantidad_kg as decimal(6,2),",
				"          monto_bs as decimal(10,2),",
				"          {_loaded_at} as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink13"
			]
		}
	}
}